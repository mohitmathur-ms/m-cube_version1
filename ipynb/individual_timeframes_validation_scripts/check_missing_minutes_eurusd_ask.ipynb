{
    "cells": [
        {
            "cell_type": "markdown",
            "metadata": {},
            "source": [
                "# Daywise missing-minutes check — EURUSD ASK 1-min\n",
                "\n",
                "For every calendar day in `EURUSD.FOREX_MS-1-MINUTE-ASK-EXTERNAL`, find minutes that are missing **between that day's first and last bar** (within-day gaps only — weekends/holidays are not flagged).\n",
                "\n",
                "Outputs:\n",
                "- console: one line per affected day (date, day_start_ts, day_end_ts, missing_count)\n",
    "- `outpuD:\m-cube_version1\catalog\data\bar\EURUSD.FOREX_MS-1-MINUTE-ASK-EXTERNALt/missing_minutes_summary_eurusd_ask.csv` — one row per affected day\n",
                "- `output/missing_minutes_eurusd_ask.csv` — one row per individual missing minute"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "from pathlib import Path\n",
                "import pandas as pd\n",
                "import pyarrow.parquet as pq\n",
                "\n",
                "BAR_DIR = Path(r\"D:\\m-cube_version1\\catalog\\data\\bar\\EURUSD.FOREX_MS-1-MINUTE-ASK-EXTERNAL\")\n",
                "OUT_DIR = Path(r\"D:\\m-cube_version1\\output\")\n",
                "OUT_DIR.mkdir(exist_ok=True)\n",
                "SUMMARY_CSV = OUT_DIR / \"missing_minutes_summary_eurusd_ask.csv\"\n",
                "MISSING_CSV = OUT_DIR / \"missing_minutes_eurusd_ask.csv\""
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "pq_path = next(BAR_DIR.glob(\"*.parquet\"))\n",
                "table = pq.read_table(pq_path, columns=[\"ts_event\"])\n",
                "ts = pd.to_datetime(table[\"ts_event\"].to_numpy(), unit=\"ns\", utc=True)\n",
                "ts = pd.DatetimeIndex(ts).sort_values()\n",
                "dup_count = int(ts.duplicated().sum())\n",
                "print(f\"file: {pq_path.name}\")\n",
                "print(f\"loaded {len(ts):,} bars  range {ts.min()} \\u2192 {ts.max()}  duplicates: {dup_count}\")\n",
                "ts = ts.drop_duplicates()"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "df = pd.DataFrame({\"ts\": ts})\n",
                "df[\"date\"] = df[\"ts\"].dt.date\n",
                "\n",
                "summary_rows = []\n",
                "missing_rows = []\n",
                "\n",
                "for day, group in df.groupby(\"date\", sort=True):\n",
                "    day_first = group[\"ts\"].iloc[0]\n",
                "    day_last = group[\"ts\"].iloc[-1]\n",
                "    expected = pd.date_range(day_first, day_last, freq=\"1min\", tz=\"UTC\")\n",
                "    actual = pd.DatetimeIndex(group[\"ts\"])\n",
                "    missing = expected.difference(actual)\n",
                "    if len(missing) == 0:\n",
                "        continue\n",
                "    summary_rows.append({\n",
                "        \"date\": day.isoformat(),\n",
                "        \"day_start_ts\": day_first.isoformat(),\n",
                "        \"day_end_ts\": day_last.isoformat(),\n",
                "        \"missing_count\": len(missing),\n",
                "    })\n",
                "    for m in missing:\n",
                "        missing_rows.append({\"date\": day.isoformat(), \"missing_ts\": m.isoformat()})\n",
                "\n",
                "print(f\"scanned {df['date'].nunique():,} days  affected: {len(summary_rows):,}  total missing minutes: {len(missing_rows):,}\")"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "print(f\"{'date':<12} {'day_start_ts':<28} {'day_end_ts':<28} missing_count\")\n",
                "for r in summary_rows:\n",
                "    print(f\"{r['date']:<12} {r['day_start_ts']:<28} {r['day_end_ts']:<28} {r['missing_count']}\")\n",
                "print(f\"\\ntotal days with gaps: {len(summary_rows):,}\")\n",
                "print(f\"total missing minutes: {sum(r['missing_count'] for r in summary_rows):,}\")"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "pd.DataFrame(summary_rows).to_csv(SUMMARY_CSV, index=False)\n",
                "pd.DataFrame(missing_rows).to_csv(MISSING_CSV, index=False)\n",
                "print(f\"wrote {SUMMARY_CSV}\")\n",
                "print(f\"wrote {MISSING_CSV}\")"
            ]
        }
    ],
