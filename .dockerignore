# ---------------------------------------------------------------------------
# Version control
# ---------------------------------------------------------------------------
.git
.gitignore
.gitattributes
.github

# ---------------------------------------------------------------------------
# Python bytecode / build artifacts
# ---------------------------------------------------------------------------
__pycache__
**/__pycache__
*.py[cod]
*$py.class
*.so
.Python
build
dist
*.egg
*.egg-info
.eggs
pip-wheel-metadata

# ---------------------------------------------------------------------------
# Virtual environments (huge — never copy into the image)
# ---------------------------------------------------------------------------
venv
.venv
env
.env
ENV
env.bak
venv.bak

# ---------------------------------------------------------------------------
# Secrets / local environment files
# ---------------------------------------------------------------------------
.env
.env.*
*.pem
*.key
*.crt
secrets/
credentials.json

# ---------------------------------------------------------------------------
# IDE / editor metadata
# ---------------------------------------------------------------------------
.vscode
.idea
*.swp
*.swo
*~
.project
.pydevproject
.spyderproject
.spyproject
.ropeproject

# ---------------------------------------------------------------------------
# OS junk
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN

# ---------------------------------------------------------------------------
# Test / coverage / linting caches
# ---------------------------------------------------------------------------
.pytest_cache
.tox
.nox
.coverage
.coverage.*
htmlcov
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis
.mypy_cache
.ruff_cache
.pyre

# ---------------------------------------------------------------------------
# Jupyter
# ---------------------------------------------------------------------------
.ipynb_checkpoints
*.ipynb

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/
*.log.*

# ---------------------------------------------------------------------------
# Generated backtest output (runtime artifact — not part of the image)
# ---------------------------------------------------------------------------
reports/
**/reports/

# ---------------------------------------------------------------------------
# Local catalog / market data (mounted at runtime, not baked in)
# ---------------------------------------------------------------------------
catalog/data
catalog/**/*.parquet
catalog/**/*.feather
catalog/**/*.csv
*.parquet
*.feather

# ---------------------------------------------------------------------------
# Databases / local stores
# ---------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# ---------------------------------------------------------------------------
# Documentation / one-off HTML notes (not needed in the runtime image)
# ---------------------------------------------------------------------------
docs/
*.html
LOGICS_BACKEND_STATUS.md
PORTFOLIO_SETUP_GUIDE.md
README*.md
how_to_use.txt
user_level_changes.txt
message*.txt

# ---------------------------------------------------------------------------
# Smoke / stress / verification scripts (run locally, not shipped)
# ---------------------------------------------------------------------------
smoke_test_*.py
stress_test_*.py
verify_*.py
tests/

# ---------------------------------------------------------------------------
# Platform-specific launchers
# ---------------------------------------------------------------------------
start.bat
*.cmd
*.ps1

# ---------------------------------------------------------------------------
# Docker itself (avoid recursive copies of the build context)
# ---------------------------------------------------------------------------
docker/
Dockerfile*
.dockerignore
docker-compose*.yml

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
LICENSE
*.bak
*.tmp
*.orig
node_modules
